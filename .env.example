# ============================================================
# LuhurWorkspace — Environment Variables
# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env
# ============================================================

# Port aplikasi (akses via http://IP:APP_PORT)
APP_PORT=8090

# URL aplikasi (ganti dengan IP VPS atau domain Anda)
APP_URL=http://YOUR_VPS_IP:8090
APP_NAME=LuhurWorkspace

# IP/domain VPS (dipakai oleh OnlyOffice untuk callback)
SERVER_IP=YOUR_VPS_IP

# Database
DB_NAME=bktdrive
DB_USER=luhuruser
DB_PASS=GantiDenganPasswordKuat123!
DB_ROOT_PASS=GantiRootPassword456!

# OnlyOffice JWT Secret (string acak panjang)
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=GantiDenganStringAcakSangatPanjang789!

# Ukuran maksimal upload (MB)
MAX_FILE_SIZE=100
